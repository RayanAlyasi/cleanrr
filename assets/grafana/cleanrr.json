      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "${DS_PROMETHEUS}"
          },
          "expr": "sum by (status) (rate(cleanrr_claude_requests_total[5m]))",
          "legendFormat": "{{status}}",
          "refId": "A"
        }
      ]
    },
