# ─── Required ────────────────────────────────────────────────────────────────

# Telegram bot token from @BotFather
TELEGRAM_BOT_TOKEN=

# ─── Authentication — set exactly ONE of the two below ──────────────────────

# Option A: Claude.ai Pro/Max subscription (recommended for personal use).
# Generate once on a machine with browser access:
#   npm install -g @anthropic-ai/claude-code
#   claude setup-token
CLAUDE_CODE_OAUTH_TOKEN=

# Option B: Anthropic API key (pay-per-token, no subscription needed).
# Get one at https://console.anthropic.com/
ANTHROPIC_API_KEY=

# ─── Behavior tuning (all optional) ──────────────────────────────────────────

# Claude model. Shorthand: opus, sonnet, haiku. Or a full ID like claude-sonnet-4-6.
# Sonnet is the default — best capability/cost balance for chat + tool use.
# Bump to opus for harder reasoning, drop to haiku for cheaper/faster replies.
CLAUDE_MODEL=sonnet

# Override the bot's built-in persona/instructions. Leave blank to use the default.
# Multi-line values are supported via quoting:
#   CLAUDE_SYSTEM_PROMPT="line one
#   line two"
CLAUDE_SYSTEM_PROMPT=

# Comma-separated Telegram user IDs allowed to run /invite. Find your ID by
# DMing @userinfobot. Empty disables /invite for everyone.
ADMIN_TELEGRAM_IDS=

# SQLite path for link codes + Telegram↔Overseerr mappings. Persists across
# restarts via the docker-compose data volume.
DATABASE_PATH=data/cleanrr.db

# How long link codes stay valid before they expire.
LINK_CODE_TTL_HOURS=24

# DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO

# ─── Docker compose interpolation ────────────────────────────────────────────

# Name of your existing media stack's Docker network (`docker network ls`).
# Common values: media, arr, arr-stack, servarr.
DOCKER_NETWORK_NAME=media

# ─── Phase 4+ (not read by the bot yet — uncomment as phases land) ──────────

# OVERSEERR_URL=http://overseerr:5055
# OVERSEERR_API_KEY=

# SONARR_URL=http://sonarr:8989
# SONARR_API_KEY=

# RADARR_URL=http://radarr:7878
# RADARR_API_KEY=

# QBIT_URL=http://qbittorrent:8080
# QBIT_USERNAME=
# QBIT_PASSWORD=
